# ═══════════════════════════════════════════════════════════════════════
# VIDEO STREAMING SERVER - ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════

# Server Configuration
NODE_ENV=production
PORT=3000

# Security
ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Redis (for caching & queues)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# FFmpeg (auto-detected if empty)
FFMPEG_PATH=
FFPROBE_PATH=

# Storage
STREAMS_DIR=./streams
CACHE_DIR=./cache
UPLOADS_DIR=./uploads
MAX_FILE_SIZE=5368709120

# VAST / Ads
VAST_TIMEOUT=5000
DEFAULT_VAST_TAG=https://pubads.g.doubleclick.net/gampad/ads?sz=640x480&iu=/124319096/external/single_ad_samples&ciu_szs=300x250&impl=s&gdfp_req=1&env=vp&output=vast&unviewed_position_start=1&cust_params=deployment%3Ddevsite%26sample_ct%3Dlinear&correlator=

# Logging
LOG_LEVEL=info

# CDN (optional)
CDN_BASE_URL=
